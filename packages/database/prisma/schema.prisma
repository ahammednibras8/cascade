generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  runtime = "nodejs"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum TaskRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum TaskAttemptStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum TaskEventLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model Project {
  id String @id @default(uuid()) @db.Uuid
  slug String @unique
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  environments Environment[]

  @@index([createdAt])
}

model Environment {
  id String @id @default(uuid()) @db.Uuid
  projectId String @db.Uuid
  slug String
  name String
  type EnvironmentType @default(DEVELOPMENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  apiKeys ApiKey[]
  tasks Task[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model ApiKey {
  id String @id @default(uuid()) @db.Uuid
  environmentId String @db.Uuid
  name String
  keyPrefix String
  keyHash String @unique
  lastUsedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId])
  @@index([keyPrefix])
}

model Task {
  id String @id @default(uuid()) @db.Uuid
  environmentId String @db.Uuid
  slug String
  name String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  runs TaskRun[]

  @@unique([environmentId, slug])
  @@index([environmentId])
}

model TaskRun {
  id String @id @default(uuid()) @db.Uuid
  taskId String @db.Uuid
  status TaskRunStatus @default(QUEUED)
  payload Json?
  output Json?
  error Json?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  attempts TaskAttempt[]
  events TaskEvent[]

  @@index([taskId, createdAt])
  @@index([status, createdAt])
}

model TaskAttempt {
  id String @id @default(uuid()) @db.Uuid
  taskRunId String @db.Uuid
  attemptNumber Int
  status TaskAttemptStatus @default(PENDING)
  error Json?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskRun TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)

  events TaskEvent[]

  @@unique([taskRunId, attemptNumber])
  @@index([taskRunId])
}

model TaskEvent {
  id String @id @default(uuid()) @db.Uuid
  taskRunId String @db.Uuid
  taskAttemptId String? @db.Uuid
  type String
  level TaskEventLevel @default(INFO)
  message String?
  data Json?
  createdAt DateTime @default(now())

  taskRun TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  taskAttempt TaskAttempt? @relation(fields: [taskAttemptId], references: [id], onDelete: SetNull)

  @@index([taskRunId, createdAt])
  @@index([taskAttemptId, createdAt])
  @@index([type, createdAt])
}