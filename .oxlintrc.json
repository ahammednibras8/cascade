{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "promise", "node", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "node": true,
    "browser": true
  },
  "ignorePatterns": [
    "node_modules/**",
    ".turbo/**",
    "dist/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**",
    "blob-report/**",
    "pnpm-lock.yaml",
    ".tshy-build/"
  ],
  "rules": {
    "no-console": "warn",
    "import/no-unassigned-import": "off",
    "no-underscore-dangle": [
      "warn",
      {
        "allow": ["_count", "_avg", "_sum", "_min", "_max"]
      }
    ]
  }
}
