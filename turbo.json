{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".react-router/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "passThroughEnv": ["DATABASE_URL"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "dependsOn": ["^build"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"]
    },
    "e2e:ui": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"]
    },
    "e2e:headed": {
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"]
    },
    "e2e:report": {
      "cache": false,
      "persistent": true
    }
  }
}
